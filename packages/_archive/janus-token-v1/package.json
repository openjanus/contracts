{
  "name": "@openjanus/janus-token",
  "version": "0.1.0",
  "description": "JanusToken — ERC-7984 confidential token with Pedersen commitments + Groth16 ZK proofs, cross-VM on Flow",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "compile": "hardhat compile",
    "test:hardhat": "hardhat test",
    "test:sdk": "vitest run tests/sdk",
    "test": "npm run test:hardhat && npm run test:sdk",
    "deploy:testnet": "hardhat run scripts/deploy-evm.ts --network flow-evm-testnet"
  },
  "dependencies": {
    "@onflow/fcl": "^1.13.0",
    "@openjanus/babyjub": "github:openjanus/primitives#main",
    "@openjanus/groth16": "github:openjanus/primitives#main",
    "@openjanus/pedersen": "github:openjanus/primitives#main",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.19.41",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "files": [
    "dist/",
    "contracts/",
    "deployments/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openjanus/contracts.git",
    "directory": "packages/janus-token"
  },
  "license": "MIT"
}
